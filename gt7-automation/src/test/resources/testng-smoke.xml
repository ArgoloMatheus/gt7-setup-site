<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    TESTNG-SMOKE.XML — Suíte apenas para Smoke Tests.
    Usada em pipelines de CI para validação rápida pós-deploy.
    Comando: mvn test -DsuiteXmlFile=src/test/resources/testng-smoke.xml
-->
<suite name="GT7 - Smoke Only" parallel="false" verbose="1">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke">
        <classes>
            <class name="com.gt7.tests.SmokeTest"/>
        </classes>
    </test>
</suite>
