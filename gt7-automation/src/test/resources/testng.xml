<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    TESTNG.XML — Configuração da suíte de testes completa.

    parallel="methods": executa métodos de teste em paralelo (threads simultâneas).
    thread-count="2": 2 browsers rodando ao mesmo tempo.
    ATENÇÃO: para paralelo funcionar, o WebDriver PRECISA ser ThreadLocal (já feito no DriverManager).
-->
<suite name="GT7 Setup Lab - Full Suite" parallel="methods" thread-count="2" verbose="1">

    <!-- Listeners: classes que "escutam" eventos do TestNG para logging e relatórios -->
    <listeners>
        <!-- AllureTestNg: coleta dados para o relatório Allure -->
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests" preserve-order="true">
        <!-- groups: executa apenas testes com a anotação @Test(groups = "smoke") -->
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.gt7.tests.SmokeTest"/>
        </classes>
    </test>

    <test name="Functional Tests">
        <classes>
            <class name="com.gt7.tests.GeneratorTest"/>
            <class name="com.gt7.tests.AdvisorTest"/>
        </classes>
    </test>

</suite>
